# Klaro web environment — canonical schema lives at apps/web/lib/env.ts.
# Every variable below is OPTIONAL. The app falls back to a labelled
# "[SIMULATED]" mock mode for any unset surface, so the app never silently
# mixes real and mock data. Copy this file to apps/web/.env.local and fill
# in the values for the surfaces you want to run live.

# ─── Supabase (auth + persistence) ─────────────────────────────────────
# Without these the app falls back to in-process fixtures in lib/mockData.ts.
# NEXT_PUBLIC_SUPABASE_URL is read by the browser bundle (DefinePlugin inlines
# the literal at build time); SUPABASE_URL is the server-side fallback name.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Licensed local-currency (fiat) payout partner for cashouts. The on-chain USDC
# lock + release run on Arc, but the fiat leg (e.g. INR via UPI) needs a licensed
# money-transmitter, which is mainnet-only. Leave UNSET on testnet: the cashout
# fiat leg is then simulated and the UI says so (cashoutFiatLive() === false).
CASHOUT_FIAT_PARTNER=

# Dev-only escape hatch. Grants the seeded mock vendor session even when
# Supabase is configured. NEVER set this in production deployments.
KLARO_ALLOW_MOCK_AUTH=

# ─── Arc testnet contracts ─────────────────────────────────────────────
# Without these the UI renders "[SIMULATED] · contracts not deployed"
# badges and reads from mock data instead of chain state.
NEXT_PUBLIC_ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network
NEXT_PUBLIC_INVOICE_ESCROW_ADDRESS=
NEXT_PUBLIC_AUDIT_RECEIPT_ADDRESS=
NEXT_PUBLIC_REFUND_PROTOCOL_ADDRESS=
NEXT_PUBLIC_FEE_SPLITTER_ADDRESS=
NEXT_PUBLIC_ROUTE_POLICY_ADDRESS=
NEXT_PUBLIC_REPUTATION_MANAGER_ADDRESS=
NEXT_PUBLIC_COUNTERPARTY_REGISTRY_ADDRESS=
# CashoutOrderProcessor — vendor signs requestAndLock here to escrow USDC for
# a cashout (LF-3 live path). When unset the cashout UI stays on the simulated
# DB-only path. The operator daemon (CASHOUT_ORDER_PROCESSOR_ADDRESS in
# apps/daemon/.env) advances the same order to RELEASED.
NEXT_PUBLIC_CASHOUT_ORDER_PROCESSOR_ADDRESS=

# Klaro treasury wallet that receives FeeSplitter + x402 fees. In live mode
# without this address, x402 `requirePayment` fails closed with HTTP 503
# rather than routing funds to the zero address.
NEXT_PUBLIC_KLARO_FEE_RECEIVER=

# ─── Circle Wallets and x402 ───────────────────────────────────────────
NEXT_PUBLIC_CIRCLE_CLIENT_KEY=        # Modular Wallets — vendor passkey provisioning
CIRCLE_API_KEY=                       # Developer-Controlled Wallets (operator)
CIRCLE_ENTITY_SECRET=                 # one-time registration; save the recovery file
CIRCLE_MODULAR_URL=

# ─── Observability ─────────────────────────────────────────────────────
# Server-side Sentry init in instrumentation.ts; client side uses the
# NEXT_PUBLIC_* counterparts further down. Without both, traces are
# server-only and the browser stays dark.
SENTRY_DSN=
SENTRY_ENV=testnet
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GROWTHBOOK_HOST=
NEXT_PUBLIC_GROWTHBOOK_CLIENT_KEY=

# ─── Outbound email + cron ─────────────────────────────────────────────
RESEND_API_KEY=                       # without it, lifecycle emails log "[MOCK]"
RESEND_FROM=Klaro <noreply@klaro.local>
CRON_SECRET=                          # required in NODE_ENV=production for /api/cron/*

# ─── Klaro Link on-chain publisher (relayer) ───────────────────────────
LINK_PUBLISHER_PRIVATE_KEY=           # server-only; relays createInvoiceFor at link pay time. Needs only gas — use a dedicated low-privilege funded wallet, NOT the operator key. Unset → link pays run the simulator.

# ─── Queue (BullMQ / Upstash) ──────────────────────────────────────────
REDIS_URL=                            # without it, queues fall back to inline mode
BULLMQ_PREFIX=klaro

# ─── Wallet pass (Apple / Google) ──────────────────────────────────────
APPLE_WALLET_PASS_TYPE_ID=
APPLE_WALLET_TEAM_ID=
APPLE_WALLET_CERT_B64=                # base64-encoded .pem certificate
APPLE_WALLET_KEY_B64=                 # base64-encoded .pem private key
GOOGLE_WALLET_ISSUER_ID=
GOOGLE_WALLET_SERVICE_ACCOUNT_B64=    # base64-encoded service-account JSON

# ─── x402 nanopayments (Circle Gateway facilitator) ────────────────────
X402_ENABLED=                         # set to "1" to flip from mock to live
X402_FACILITATOR_URL=

# ─── Web Push ──────────────────────────────────────────────────────────
# Even when set, push subscriptions require a UI CTA on /vendor/settings
# to actually trigger registration.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── Card on-ramp ──────────────────────────────────────────────────────
NEXT_PUBLIC_MOONPAY_PUBLIC_KEY=
MOONPAY_SECRET_KEY=

# ─── Webhook signing ───────────────────────────────────────────────────
WEBHOOK_HMAC_SECRET=

# ─── WalletConnect (mobile wallet support for buyer pay flow) ──────────
# Without this, only injected browser wallets (MetaMask, Phantom, Rabby,
# Coinbase, Brave) appear in the buyer's wallet picker. Set this to enable
# mobile wallets (Trust, mobile MetaMask, Rainbow, 1inch, …) via QR scan.
# Free project id: https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# ─── WebAuthn (passkey verification) ───────────────────────────────────
# WEBAUTHN_RP_ID is your domain without scheme or port (e.g. "klaro.so").
# It must match the origin where the passkey was registered.
# WEBAUTHN_EXPECTED_ORIGIN is the full URL the user signs in from.
# Defaults are for local development.
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Klaro
WEBAUTHN_EXPECTED_ORIGIN=http://localhost:3000

# ─── Screening providers ───────────────────────────────────────────────
# Each key, when set, flips one row in /admin/sanctions from "credentials
# pending" to live. Wiring the live results into the daemon's
# screen-and-settle worker lands alongside provider integration. Until
# then the admin UI labels each provider honestly as credentials pending.
CHAINALYSIS_API_KEY=
TRM_API_KEY=
SUMSUB_APP_TOKEN=
ELLIPTIC_API_KEY=

# ─── Inbound webhook secrets ───────────────────────────────────────────
# One per provider. When unset, the matching receiver under
# /api/webhooks/{stripe,circle,cctp,gateway,erp} returns
# `503 ${provider}_secret_missing`.
STRIPE_WEBHOOK_SECRET=
CIRCLE_WEBHOOK_SECRET=
CCTP_WEBHOOK_SECRET=
GATEWAY_WEBHOOK_SECRET=
ERP_WEBHOOK_SECRET=

# ─── Public origin ─────────────────────────────────────────────────────
# Used to build pasteable share URLs from /vendor/invoices/[id] and
# similar share surfaces. Set explicitly on preview branches so copied
# links don't point at production by accident.
NEXT_PUBLIC_PUBLIC_ORIGIN=

# ─── Queue worker flag ─────────────────────────────────────────────────
# Set to "1" on the daemon (long-lived process) so it actually drains
# queues. The web app on serverless leaves this unset — handlers run in
# the daemon's process. A typo here silently leaves jobs unprocessed.
KLARO_RUN_QUEUE_WORKER=

# ─── Client-side Sentry ────────────────────────────────────────────────
# Next.js inlines NEXT_PUBLIC_* variables into the client bundle. Set
# these alongside SENTRY_DSN / SENTRY_ENV above; without both, browser
# telemetry stays dark while server traces flow.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENV=testnet
