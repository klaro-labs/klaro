# Klaro daemon env — canonical schema lives at apps/daemon/src/env.ts.
# Required vars have no default; optional vars are noted with `# optional`.
# Audit fix (loop iter 49, 2026-05-25): file created from the zod schema
# so new operators have a single document to fill in.

NODE_ENV=development
PORT=8787

# Supabase service-role (RLS bypass — daemon writes across vendors)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Redis / BullMQ — defaults to local redis://127.0.0.1:6379
REDIS_URL=redis://127.0.0.1:6379  # optional
BULLMQ_PREFIX=klaro               # optional

# Arc RPC for event subscriptions — defaults to public testnet
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network  # optional (canonical per docs.arc.io)

# Contract addresses — pinned post-deploy so daemon doesn't need redeploy on address change
INVOICE_ESCROW_ADDRESS=               # optional
AUDIT_RECEIPT_ADDRESS=                # optional
CASHOUT_ORDER_PROCESSOR_ADDRESS=      # optional
AGENT_ESCROW_ADDRESS=                 # optional
# RetainerStream escrow — the dispute→escrow fan-out resolves stream-context
# cases here; without it a decided stream dispute can't be auto-resolved.
RETAINER_STREAM_ADDRESS=              # optional
DISPUTE_MANAGER_ADDRESS=              # optional

# Operator wallet for daemon-signed txs (Circle Wallets OR local key)
DAEMON_OPERATOR_WALLET_ID=            # optional (Circle Wallets)
DAEMON_OPERATOR_PRIVATE_KEY=          # optional (local keystore — testnet only)

# Outbound email (Resend)
RESEND_API_KEY=                       # optional — without it, lifecycle emails log to console
RESEND_FROM=Klaro <noreply@klaro.so>  # optional

# Webhook delivery signing — HMAC-SHA256 (Stripe-style)
WEBHOOK_HMAC_SECRET=                  # optional — without it, deliveries sign with literal "mock"

# Alerts
PAGERDUTY_INTEGRATION_KEY=            # optional — DLQ backlog > 10 silently skipped without
SENTRY_DSN=                           # optional — server-side telemetry off without

# Iter 30: declared so HUMAN_ACTIONS-listed workers can flip from [SIMULATED] when wired.
CHAINALYSIS_API_KEY=                  # optional — sanctionsRefresh worker stays [SIMULATED] without
SUMSUB_APP_TOKEN=                     # optional — screenAndSettle worker stays deterministic-pass without
VAPID_PRIVATE_KEY=                    # optional — push notification sender (UI CTA also missing — see HUMAN_ACTIONS)
